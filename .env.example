# =============================================================================
# InsightLoop configuration
# Copy this file to `.env` and fill in your secrets.
# =============================================================================

# ---- LLM provider ---------------------------------------------------------
# One of: openai | anthropic | ollama | mock
# `mock` requires no provider API key and is great for local demos and CI.
LLM_PROVIDER=openai

# ---- OpenAI ---------------------------------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Anthropic ------------------------------------------------------------
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Ollama (local LLM) ---------------------------------------------------
# https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- App ------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ---- Write/API protection -------------------------------------------------
# Mutating endpoints are disabled until either API key auth or browser login is configured.
# REST clients: send `Authorization: Bearer <INSIGHTLOOP_API_KEY>` or `X-InsightLoop-API-Key`.
INSIGHTLOOP_API_KEY=

# Browser UI login for Analyze / Save / Upload / Delete actions.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_SECRET=
SECURE_COOKIES=false

# ---- Database -------------------------------------------------------------
# SQLite by default. Use a full URL for Postgres/MySQL in production.
DATABASE_URL=sqlite:///./data/insightloop.db

# ---- Storage --------------------------------------------------------------
# Where uploaded CSVs and generated reports are kept.
DATA_DIR=./data
